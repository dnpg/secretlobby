# ==============================================================================
# secretlobby.co - Environment Configuration
# ==============================================================================

# Environment (development / production)
NODE_ENV=production
VITE_ENV=production

# Core domain configuration
# This is your base domain used for subdomains (e.g., yourband.secretlobby.co)
# For local: CORE_DOMAIN=secretlobby.local
# For production: CORE_DOMAIN=secretlobby.co (or your actual domain)
CORE_DOMAIN=secretlobby.co

# Console URL (used by marketing app for Sign In/Sign Up links)
# For local: CONSOLE_URL=//console.secretlobby.local
# For production: CONSOLE_URL=//console.secretlobby.co
CONSOLE_URL=//console.secretlobby.co

# Console base URL — absolute origin of the console app. Used as the
# base for Stripe Checkout success/cancel URLs and Customer Portal
# return URLs. We deliberately do NOT derive this from the request's
# `Host` header — a misconfigured upstream proxy that forwards an
# attacker-controlled Host would otherwise turn Stripe's post-checkout
# redirect into an open redirect (`evil.com/billing/success?session_id=…`).
# Must be the full http(s) origin, no path, no trailing slash. Required
# for billing intents (checkout, customer portal, cancel).
# For local: APP_BASE_URL=http://console.secretlobby.local:3001
# For production: APP_BASE_URL=https://console.secretlobby.co
APP_BASE_URL=https://console.secretlobby.co

# Docker Compose profiles
# dev = includes Adminer for database management
# Leave empty or remove for production
COMPOSE_PROFILES=dev

# Session Secret (REQUIRED - minimum 32 characters)
# SECURITY: Generate a unique secret for each environment (dev/staging/prod)
# Generate with: openssl rand -base64 32
# Or with Node: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER commit real secrets to git - this is just an example
SESSION_SECRET=your-super-secret-session-key-min-32-chars-REPLACE-ME-WITH-REAL-SECRET

# Admin API Secret (for cross-service admin operations)
# Used by super-admin to call protected admin API endpoints in lobby apps
# Generate with: openssl rand -base64 32
# Or with Node: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_API_SECRET=your-admin-api-secret-min-32-chars-REPLACE-ME-WITH-REAL-SECRET

# Lobby Password Encryption Keys (REQUIRED in production)
# Encrypts the per-lobby password column at rest with AES-256-GCM. Each row
# embeds the id of the key it was encrypted under (format:
# enc:v1:<keyId>:<base64...>), so multiple keys can be live at once during
# a rotation.
#
# Set ONE OR MORE LOBBY_PASSWORD_KEY_<id> vars — each must decode to
# exactly 32 bytes. Pick short ids like "k1", "2026q2", "primary".
# Then point LOBBY_PASSWORD_ACTIVE_KEY_ID at the id new writes should use.
#
# Generate a key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Rotation runbook (when you eventually need it):
#   1. Add a second LOBBY_PASSWORD_KEY_<new-id> alongside the existing one.
#   2. Flip LOBBY_PASSWORD_ACTIVE_KEY_ID to the new id. Deploy.
#   3. Run packages/db/prisma/scripts/encrypt-lobby-passwords.ts — it
#      rewrites every row under the active key.
#   4. Remove the old LOBBY_PASSWORD_KEY_<old-id> from env on the next
#      deploy.
#
# DO NOT delete a key while rows still reference it (the script will tell
# you if any do). Back these up with your other prod secrets — losing a
# key makes every row encrypted under it unrecoverable.
LOBBY_PASSWORD_KEY_k1=replace-with-base64-of-32-random-bytes
LOBBY_PASSWORD_ACTIVE_KEY_ID=k1

# Database (PostgreSQL)
POSTGRES_USER=secretlobby
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=secretlobby
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (for Prisma)
# For local development (outside Docker):
DATABASE_URL=postgresql://secretlobby:your-secure-password-here@localhost:5432/secretlobby
# For Docker (use postgres as host):
# DATABASE_URL=postgresql://secretlobby:your-secure-password-here@postgres:5432/secretlobby

# Database Migrations
# Migrations run automatically via the "migrate" service before apps start
# Uses: depends_on: migrate: condition: service_completed_successfully

# Redis
REDIS_URL=redis://localhost:6379

# Legacy settings (for backwards compatibility with lobby password)
SITE_PASSWORD=your-site-password-here

# =============================================================================
# Authentication
# =============================================================================

# Super Admin (initial platform admin)
# Run after setting these: pnpm db:create-super-admin (production: use this only; do not run the full seed).
# Local: set in repo root .env then run the command. Log in at Super Admin (e.g. http://localhost:3003) with this email and password.
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=your-secure-admin-password

# Google OAuth (get credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth callback URL (update for production)
AUTH_URL=http://localhost:5173

# Optional: Restrict Google login to specific domain(s)
# GOOGLE_ALLOWED_DOMAINS=yourdomain.com,anotherdomain.com

# Email
# Production: use Resend (set RESEND_API_KEY, leave SMTP_* unset).
# Local: use Mailpit (docker-compose dev profile). Set SMTP_HOST so mail is caught locally.
# Mailpit Web UI: http://localhost:8025 when running with COMPOSE_PROFILES=dev
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=SecretLobby <noreply@secretlobby.co>
# Local email testing (Mailpit) - set these to use SMTP instead of Resend
# SMTP_HOST=localhost
# SMTP_PORT=1025

# =============================================================================
# Cloudflare R2 Storage
# =============================================================================

# Get credentials from Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=secretlobby-media
# Optional: base directory prefix for all objects (e.g., "media" or "production/assets")
# Leave empty or unset to store at the bucket root
R2_BASE_PREFIX=
# Public URL for your R2 bucket (custom domain or r2.dev subdomain)
R2_PUBLIC_URL=https://cdn.secretlobby.co

# =============================================================================
# Image Transformations
# =============================================================================

# Image transformation URL pattern (Cloudflare, Cloudinary, Imgix, or custom)
# Use {url}, {origin}, {path}, {width}, {quality}, {format} placeholders
# Cloudflare: {origin}/cdn-cgi/image/width={width},quality={quality},format={format}/{path}
# Cloudinary: https://res.cloudinary.com/CLOUD/image/fetch/w_{width},q_{quality},f_{format}/{url}
# Imgix: {url}?w={width}&q={quality}&auto=format
# Passthrough (no transform): {url}
IMAGE_TRANSFORM_PATTERN={origin}/cdn-cgi/image/width={width},quality={quality},format={format}/{path}

# =============================================================================
# Stripe Payments — subscription billing
# =============================================================================
#
# Subscriptions are powered by packages/payments/src/billing. The
# canonical price catalog lives in the SubscriptionPlan table — edit
# prices via the super-admin Plans page, then paste the price_... ids
# Stripe gives you into each plan row.
#
# Local development: use Stripe's test mode and the Stripe CLI to
# forward webhooks to your dev console:
#   stripe listen --forward-to http://localhost:3001/api/webhooks/stripe
# The CLI prints a `whsec_...` value — paste that into
# STRIPE_WEBHOOK_SECRET below.

# Stripe secret key. NEVER expose this to the client — it grants full
# API access (can create charges, refund payments, view customer data).
# Get at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe publishable key — safe to expose to the client (it's already in
# Stripe.js script tags on the open internet). Used by the future
# Stripe Elements integration; not required for Checkout-only flows.
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret. Anyone with this value can forge webhooks
# against your account, granting themselves any subscription tier.
# Treat it like STRIPE_SECRET_KEY. Get from Stripe Dashboard →
# Developers → Webhooks → (your endpoint) → "Signing secret".
# Format: whsec_... (32+ chars).
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Legacy Stripe price-id env vars (no longer used by the new billing
# module — the SubscriptionPlan table is canonical). Kept here so
# existing deployments don't break on a missing-var check. To migrate:
# create SubscriptionPlan rows in super-admin and paste the same
# price_... ids into the stripePriceMonthly / stripePriceYearly columns.
# -----------------------------------------------------------------------------
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# =============================================================================
# PayPal Payments (Optional - for future use)
# =============================================================================

# Get credentials at https://developer.paypal.com
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=

# =============================================================================
# Analytics
# =============================================================================

# Google Analytics & Tag Manager (Marketing site)
GA_MEASUREMENT_ID=
GTM_CONTAINER_ID=

# Google Analytics (Console + Super Admin)
CONSOLE_GA_MEASUREMENT_ID=
