// Multi-tenant schema for secretlobby.co
// Band/Artist lobby landing pages platform

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/client"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  OWNER // Full access, can delete account
  ADMIN // Full access except account deletion
  EDITOR // Can edit lobbies and content
  VIEWER // Read-only access
}

enum DomainStatus {
  PENDING // DNS not yet verified
  VERIFIED // DNS verified and active
  FAILED // DNS verification failed
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
  TRIALING
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum MediaType {
  IMAGE
  AUDIO
  VIDEO
  EMBED
}

enum EmbedProvider {
  YOUTUBE
  VIMEO
}

enum ViolationStatus {
  ACTIVE   // Currently tracking violations
  RESOLVED // User succeeded after violations
  BLOCKED  // IP is blocked
  EXPIRED  // Violations aged out
}

enum InvitationStatus {
  PENDING   // Not yet used
  USED      // Account created
  EXPIRED   // Time expired
  REVOKED   // Admin revoked
}

enum FeedbackType {
  BUG_REPORT
  FEATURE_REQUEST
  GENERAL
}

enum FeedbackStatus {
  PENDING
  READ
  ARCHIVED
}

/// Staff can access super-admin. Independent of Account; same User can be staff and/or in band accounts.
enum StaffRole {
  OWNER  // Can manage staff and full super-admin access
  ADMIN  // Full super-admin access, cannot manage staff
}

/// Who is allowed to enter a Lobby. Composes with identity flags
/// (identityEmail / identityGoogle / passwordRequired) on the Lobby row.
enum LobbyAccessPolicy {
  PUBLIC           // Anyone (subject to optional password gate)
  INVITE_ONLY      // Only emails on the LobbyUser invite list
  DOMAIN_ALLOWLIST // Only emails whose domain matches Lobby.allowedDomains
}

/// LobbyUser lifecycle. PENDING = invited but never signed in. ACTIVE =
/// has successfully consumed at least one magic link or Google sign-in.
enum LobbyUserStatus {
  PENDING
  ACTIVE
}

// ============================================================================
// ACCOUNT (Tenant)
// ============================================================================

model Account {
  id   String @id @default(cuid())
  name String // Organization/Band name
  slug String @unique // Subdomain: {slug}.secretlobby.co

  // Subscription & Billing
  subscriptionTier SubscriptionTier @default(FREE)
  stripeCustomerId String?          @unique

  // Global account settings (JSON)
  settings Json @default("{}")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users          AccountUser[]
  lobbies        Lobby[]
  domains        Domain[]
  media          Media[]
  subscriptions  Subscription[]
  paymentMethods PaymentMethod[]
  paymentHistory PaymentHistory[]
  feedback       Feedback[]
  swatches       Swatch[]
  defaultLobbyId String? // Reference to the default lobby

  @@index([slug])
}

// ============================================================================
// SWATCH (Saved color/gradient swatches per account — used by ColorPicker)
// ============================================================================

model Swatch {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // User-supplied label shown in the saved-swatches grid.
  name  String
  // "solid" or "gradient" — mirrors the ColorValue.type field in app code.
  kind  String
  // Full ColorValue payload (SolidValue | GradientValue).
  value Json

  createdAt DateTime @default(now())

  @@index([accountId])
}

// ============================================================================
// USER
// ============================================================================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  firstName    String?
  lastName     String?
  /// Display name (editable; can default to firstName)
  name         String?
  avatarUrl    String?

  // Email verification
  emailVerified    Boolean @default(false)
  emailVerifyToken String?
  /// Pending email address for email-change flow (only applied after verification)
  pendingEmail     String?

  // Password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // Login lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  accounts          AccountUser[]
  sessions          Session[]
  staff             Staff?
  feedback          Feedback[]
  invitedLobbyUsers LobbyUser[]   @relation("LobbyUserInvitedBy")

  @@index([email])
}

// ============================================================================
// STAFF (Super-admin access; separate from Account membership)
// ============================================================================

model Staff {
  id        String    @id @default(cuid())
  userId    String    @unique
  role      StaffRole @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// ACCOUNT USER (Junction table with role)
// ============================================================================

model AccountUser {
  id        String   @id @default(cuid())
  accountId String
  userId    String
  role      UserRole @default(VIEWER)

  // Invitation tracking
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?
  invitedBy  String? // User ID who sent the invite

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([accountId])
  @@index([userId])
}

// ============================================================================
// SESSION
// ============================================================================

model Session {
  id     String @id @default(cuid())
  userId String
  token  String @unique

  // Session context
  accountId String? // Currently active account
  userAgent String?
  ipAddress String?

  // Timestamps
  createdAt DateTime @default(now())
  expiresAt DateTime

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ============================================================================
// LOBBY (Landing Page)
// ============================================================================

model Lobby {
  id        String @id @default(cuid())
  accountId String

  // Basic info
  name        String // Internal name
  slug        String // URL path: {account-slug}.secretlobby.co/{lobby-slug}
  title       String? // Public title
  description String? // Public description

  // Status
  isPublished Boolean @default(false)
  isDefault   Boolean @default(false) // Is this the account's default lobby?

  // Access control
  //
  // The model is two orthogonal axes — see LobbyAccessPolicy enum.
  //   * accessPolicy  : WHO is allowed in (Public / Invite / Domain).
  //   * identityEmail : visitor enters their email + receives a magic link.
  //   * identityGoogle: visitor signs in with Google (OAuth client shared
  //                     with the console).
  //   * passwordRequired: shared password gate (always layered on top of
  //                     whatever else is enabled; password text lives in
  //                     `password`, encrypted at rest).
  //
  // Validation (enforced in the mutation layer): if accessPolicy is not
  // PUBLIC, at least one of identityEmail / identityGoogle must be true,
  // otherwise we have no way to identify the visitor.
  password         String? // Encrypted shared password (see @secretlobby/auth/lobby-password)
  requiresAuth     Boolean @default(false)
  accessPolicy     LobbyAccessPolicy @default(PUBLIC)
  identityEmail    Boolean @default(false)
  identityGoogle   Boolean @default(false)
  passwordRequired Boolean @default(false)
  allowedDomains   String[] @default([]) // e.g. ["acme.com", "partner.io"] — only consulted when accessPolicy = DOMAIN_ALLOWLIST

  // Content & Settings (JSON)
  // Includes: theme, background, banner, playlist, band info, etc.
  settings Json @default("{}")

  // Media references (FK to Media table)
  backgroundMediaId     String?
  backgroundMediaDarkId String?
  bannerMediaId         String?
  bannerMediaDarkId     String?
  profileMediaId        String?
  profileMediaDarkId    String?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Relations
  account             Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tracks              Track[]
  playlists           Playlist[]
  lobbyUsers          LobbyUser[]
  rateLimitViolations RateLimitViolation[] @relation("LobbyViolations")
  backgroundMedia     Media?               @relation("LobbyBackground", fields: [backgroundMediaId], references: [id], onDelete: SetNull)
  backgroundMediaDark Media?               @relation("LobbyBackgroundDark", fields: [backgroundMediaDarkId], references: [id], onDelete: SetNull)
  bannerMedia         Media?               @relation("LobbyBanner", fields: [bannerMediaId], references: [id], onDelete: SetNull)
  bannerMediaDark     Media?               @relation("LobbyBannerDark", fields: [bannerMediaDarkId], references: [id], onDelete: SetNull)
  profileMedia        Media?               @relation("LobbyProfile", fields: [profileMediaId], references: [id], onDelete: SetNull)
  profileMediaDark    Media?               @relation("LobbyProfileDark", fields: [profileMediaDarkId], references: [id], onDelete: SetNull)

  @@unique([accountId, slug])
  @@index([accountId])
  @@index([slug])
}

// ============================================================================
// LOBBY USER (Per-lobby visitor identified by email and/or Google sub)
// ============================================================================
//
// One row per (lobbyId, email). Serves two roles depending on how it was
// created:
//   * Admin pre-creates rows (status=PENDING) to populate an invite list
//     before anyone has clicked through.
//   * The lobby login flow creates rows on demand when a visitor enters
//     an email + correct password (PUBLIC + identityEmail mode), or
//     completes Google sign-in.
//
// The magic-link token lives on this row (mirrors the User password-reset
// pattern). One outstanding token per user at a time — issuing a new link
// invalidates any previous one. Tokens are random hex, single-use,
// short-lived (see LOBBY_MAGIC_LINK_TTL_MS in @secretlobby/auth).

model LobbyUser {
  id      String @id @default(cuid())
  lobbyId String
  email   String // Always lowercased before write — see normalizeEmail()

  status    LobbyUserStatus @default(PENDING)
  googleSub String? // Stable Google "sub" claim; populated on first Google sign-in

  // Magic-link state. Token is random hex (crypto.randomBytes(32).toString("hex")).
  // Cleared on successful consume; we never re-use tokens.
  magicLinkToken     String?   @unique
  magicLinkExpiresAt DateTime?
  magicLinkSentAt    DateTime?

  // Audit
  invitedByUserId String? // Admin User who added this row, if any
  invitedAt       DateTime?
  firstLoginAt    DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lobby       Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  invitedBy   User? @relation("LobbyUserInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([lobbyId, email])
  @@index([lobbyId])
  @@index([email])
  @@index([googleSub])
  @@index([magicLinkExpiresAt])
}

// ============================================================================
// PLAYLIST (Named playlists scoped to a lobby; group tracks for player blocks)
// ============================================================================

model Playlist {
  id        String   @id @default(cuid())
  lobbyId   String
  name      String
  position  Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lobby  Lobby   @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@unique([lobbyId, name])
  @@index([lobbyId, position])
}

// ============================================================================
// TRACK (Audio tracks for a lobby)
// ============================================================================

model Track {
  id      String @id @default(cuid())
  lobbyId String

  // Phase 6: tracks are owned by a playlist. Nullable initially so the
  // backfill can run; future migration will tighten to NOT NULL once prod
  // is verified to have zero null playlistId.
  playlistId String?

  // Track info
  title    String
  artist   String?
  filename String // Storage reference (legacy — prefer media relation)
  duration Int? // Duration in seconds (legacy — prefer media.duration)

  // HLS streaming (legacy — prefer media.hlsReady / media.waveformPeaks)
  hlsReady      Boolean @default(false)
  waveformPeaks Json? // number[] — pre-computed waveform peak amplitudes

  // Media reference (new)
  mediaId String?

  // Optional cover image (FK to Media) — separate from the audio mediaId.
  coverMediaId String?

  // Ordering (within playlist; lobbyId kept as denormalized cache for
  // legacy queries and convenience joins).
  position Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lobby      Lobby     @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  playlist   Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  media      Media?    @relation("TrackAudioMedia", fields: [mediaId], references: [id], onDelete: SetNull)
  coverMedia Media?    @relation("TrackCoverMedia", fields: [coverMediaId], references: [id], onDelete: SetNull)

  @@index([lobbyId])
  @@index([lobbyId, position])
  @@index([playlistId])
  @@index([playlistId, position])
  @@index([mediaId])
  @@index([coverMediaId])
}

// ============================================================================
// DOMAIN (Custom domains)
// ============================================================================

model Domain {
  id        String @id @default(cuid())
  accountId String

  // Domain info
  domain String @unique // e.g., "music.mybandname.com"

  // Verification
  status            DomainStatus @default(PENDING)
  verificationToken String       @unique @default(cuid())
  verifiedAt        DateTime?
  lastCheckedAt     DateTime?

  // SSL
  sslEnabled   Boolean   @default(false)
  sslExpiresAt DateTime?

  // Target lobby (optional - defaults to account's default lobby)
  lobbyId String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([accountId])
}

// ============================================================================
// MEDIA (Centralized media library)
// ============================================================================

model Media {
  id        String @id @default(cuid())
  accountId String

  filename  String       // Original filename
  key       String       // R2 object key (empty for embeds)
  mimeType  String       // e.g. "image/jpeg"
  size      Int          // File size in bytes
  type      MediaType

  width     Int?         // Image-only
  height    Int?         // Image-only
  duration  Int?         // Audio/Video duration in seconds
  alt       String?      // User-editable alt text (also used for search)

  // Audio processing
  hlsReady      Boolean @default(false)
  waveformPeaks Json?   // number[] — pre-computed waveform peak amplitudes
  metadata      Json?   // Additional metadata (e.g. audio codec info)

  provider  EmbedProvider?  // YouTube or Vimeo
  embedUrl  String?         // Full embed URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Inverse relations (Lobby media slots)
  lobbyBackgrounds     Lobby[] @relation("LobbyBackground")
  lobbyBackgroundDarks Lobby[] @relation("LobbyBackgroundDark")
  lobbyBanners         Lobby[] @relation("LobbyBanner")
  lobbyBannerDarks     Lobby[] @relation("LobbyBannerDark")
  lobbyProfiles        Lobby[] @relation("LobbyProfile")
  lobbyProfileDarks    Lobby[] @relation("LobbyProfileDark")

  // Inverse relations (Tracks using this media as audio or cover)
  tracks       Track[] @relation("TrackAudioMedia")
  trackCovers  Track[] @relation("TrackCoverMedia")

  @@index([accountId, type])
  @@index([accountId, createdAt])
}

// ============================================================================
// AUDIT LOG (Optional - for tracking changes)
// ============================================================================

model AuditLog {
  id        String  @id @default(cuid())
  accountId String?
  userId    String?

  // Action details
  action     String // e.g., "lobby.created", "domain.verified"
  entityType String? // e.g., "Lobby", "Domain"
  entityId   String?

  // Change data
  oldData Json?
  newData Json?

  // Context
  ipAddress String?
  userAgent String?

  // Timestamps
  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================================
// SUBSCRIPTION (Payment subscriptions)
// ============================================================================

model Subscription {
  id        String @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Gateway info
  gatewayId             String // 'stripe', 'paypal', etc.
  gatewaySubscriptionId String // External subscription ID
  gatewayCustomerId     String // External customer ID

  // Linked SubscriptionPlan (preferred source of truth for tier/limits).
  // Kept optional for backward-compat with rows created before plan
  // catalog existed; new writes always populate it.
  planId    String?
  plan      SubscriptionPlan? @relation(fields: [planId], references: [id])

  // Subscription details. `tier` is a legacy enum mirror of `plan.slug`
  // — keep it in sync so existing code that reads `account.subscriptionTier`
  // keeps working until everything has migrated to plan-based lookups.
  tier                SubscriptionTier
  status              SubscriptionStatus @default(ACTIVE)
  billingPeriod       String?            // 'monthly' or 'yearly'

  // Stripe price the subscription is currently billed on. Used to detect
  // plan changes from Stripe-initiated updates (Customer Portal, retries).
  gatewayPriceId      String?

  // Billing cycle
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean  @default(false)

  // Out-of-order webhook protection. Stamp of the most recent Stripe
  // event we have applied to this row. Older events (by event.created)
  // are dropped — see packages/payments/src/billing/webhook.server.ts.
  lastEventAt         DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gatewayId, gatewaySubscriptionId])
  @@index([accountId])
  @@index([status])
  @@index([planId])
}

// ============================================================================
// PAYMENT METHOD
// ============================================================================

model PaymentMethod {
  id        String @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Gateway info
  gatewayId               String
  gatewayPaymentMethodId  String

  // Card details (for display only - no sensitive data)
  type        String    // 'card', 'paypal', 'bank_account'
  last4       String?
  brand       String?   // 'visa', 'mastercard', etc.
  expiryMonth Int?
  expiryYear  Int?

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([accountId])
}

// ============================================================================
// PAYMENT HISTORY
// ============================================================================

model PaymentHistory {
  id             String  @id @default(cuid())
  accountId      String
  account        Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subscriptionId String?

  // Gateway info
  gatewayId        String
  gatewayPaymentId String

  // Payment details
  amount      Int           // In cents
  currency    String        @default("usd")
  status      PaymentStatus
  description String?

  // URLs for receipts/invoices
  invoiceUrl  String?
  receiptUrl  String?

  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([createdAt])
}

// ============================================================================
// SYSTEM SETTINGS (Platform-wide configuration)
// ============================================================================

model SystemSettings {
  id    String @id @default("default") // Singleton - always "default"

  // Payment Gateway Configuration
  enabledGateways  String[] @default(["stripe"]) // ['stripe', 'paypal']
  defaultGateway   String   @default("stripe")

  // Platform Settings
  platformName     String   @default("SecretLobby")
  supportEmail     String   @default("support@secretlobby.co")

  // Feature Flags
  allowSignups     Boolean  @default(true)
  maintenanceMode  Boolean  @default(false)
  prelaunchMode    Boolean  @default(false)

  // Page Builder
  // When true, the page-builder's per-section grid-template-columns inputs
  // (Desktop / Tablet / Mobile) are hidden from customers. Layout still
  // works because new sections are seeded with sensible defaults
  // (mobile = 1fr, tablet/desktop = "1fr 300px"). Default ON so customers
  // don't see the raw grid-template controls until super-admin opts in.
  disableColumnSizeEditor Boolean @default(true)

  // Feedback Notifications
  feedbackNotificationEmail String?

  // Favicon & Web Manifest Configuration (JSON)
  // Contains: sourceKey, generatedAt, manifestName, manifestShortName, themeColor, bgColor, display
  faviconConfig    Json     @default("{}")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// SUBSCRIPTION PLAN (Configurable subscription plans)
// ============================================================================

model SubscriptionPlan {
  id          String  @id @default(cuid())

  // Plan Identity
  name        String           // Display name (e.g., "Starter")
  slug        String  @unique  // Internal identifier (e.g., "STARTER")
  description String?          // Short description

  // Pricing (in cents)
  priceMonthly Int    @default(0)
  priceYearly  Int    @default(0)
  currency     String @default("usd")

  // External Gateway Price IDs
  stripePriceMonthly String?  // Stripe price ID for monthly
  stripePriceYearly  String?  // Stripe price ID for yearly
  paypalPlanMonthly  String?  // PayPal plan ID for monthly
  paypalPlanYearly   String?  // PayPal plan ID for yearly

  // Features (JSON array of feature strings)
  features Json @default("[]")

  // Limits
  maxSongs     Int     @default(5)     // Max songs allowed
  maxLobbies   Int     @default(1)     // Max lobbies allowed
  maxStorage   Int     @default(100)   // Max storage in MB
  customDomain Boolean @default(false) // Allow custom domains
  apiAccess    Boolean @default(false) // Allow API access

  // Display
  highlighted Boolean @default(false)  // Show as "Most Popular"
  position    Int     @default(0)      // Sort order
  isActive    Boolean @default(true)   // Show in pricing page

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive, position])
  // Used by Subscription upserts to resolve plan from a Stripe price ID.
  @@index([stripePriceMonthly])
  @@index([stripePriceYearly])
}

// ============================================================================
// STRIPE WEBHOOK EVENT (Idempotency Ledger)
// ============================================================================

/// Idempotency ledger for incoming gateway webhook events. We INSERT a row
/// keyed by (gatewayId, eventId) BEFORE applying the event. If the insert
/// hits the unique constraint we treat the event as already-processed and
/// return 200 without touching anything else. See
/// packages/payments/src/billing/webhook.server.ts.
///
/// Rows are immutable except for `processedAt` (filled in on success).
/// Failed rows stay PENDING so the next retry can resume work — Stripe
/// will keep redelivering until we ack 2xx.
model StripeWebhookEvent {
  id          String   @id @default(cuid())

  /// 'stripe' for now. Future-proofed for paypal etc.
  gatewayId   String

  /// The external event id from the gateway (e.g. "evt_..." for Stripe).
  eventId     String

  /// The Stripe event type string (e.g. "customer.subscription.updated").
  /// Stored verbatim so we can audit which event types we have seen.
  eventType   String

  /// Stripe event creation timestamp. Used both for ordering and for
  /// log/audit purposes. Wall-clock from Stripe, not from us.
  eventCreatedAt DateTime

  /// When we first received the event (insert time on our side).
  receivedAt  DateTime @default(now())

  /// When we finished applying the event. NULL means we crashed or errored
  /// after the idempotency insert but before commit — the next retry will
  /// reprocess (the actual mutations run in a transaction with this row's
  /// processedAt update, so partial work is impossible).
  processedAt DateTime?

  /// Optional last-error message for debugging failed deliveries.
  /// Never contains request body / signature material.
  error       String?

  @@unique([gatewayId, eventId])
  @@index([eventType])
  @@index([receivedAt])
}

// ============================================================================
// RATE LIMIT VIOLATION (Security & Brute Force Protection)
// ============================================================================

model RateLimitViolation {
  id             String          @id @default(cuid())

  // Identification
  ipAddress      String
  endpoint       String          // "login", "lobby-password", "signup", etc.
  resourceId     String?         // Lobby ID, account ID, etc.

  // Tracking
  violationCount Int             @default(1)
  firstViolation DateTime        @default(now())
  lastViolation  DateTime        @updatedAt
  lockoutUntil   DateTime?
  status         ViolationStatus @default(ACTIVE)

  // Additional Context
  userAgent      String?
  metadata       Json?           // Any additional context (geo, fingerprint, etc.)

  // Timestamps
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  lobby          Lobby?          @relation("LobbyViolations", fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([ipAddress, endpoint, resourceId])
  @@index([status, lockoutUntil])
  @@index([lastViolation])
  @@index([createdAt])
}

// ============================================================================
// INTERESTED PERSON (Marketing email collection)
// ============================================================================

model InterestedPerson {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  source       String?     // e.g., "marketing-hero", "marketing-cta"
  ipAddress    String?
  userAgent    String?
  inviteSentAt DateTime?   // When invite was sent
  convertedAt  DateTime?   // When they signed up
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  invitation   Invitation?

  @@index([email])
  @@index([createdAt])
}

// ============================================================================
// INVITATION (Invite links for prelaunch)
// ============================================================================

model Invitation {
  id                 String           @id @default(cuid())
  email              String           @unique
  code               String           @unique  // 64-char secure token
  status             InvitationStatus @default(PENDING)
  sentAt             DateTime?
  usedAt             DateTime?
  expiresAt          DateTime         // Default 7 days from creation
  sentBy             String?          // Admin user ID
  note               String?
  interestedPersonId String?          @unique
  interestedPerson   InterestedPerson? @relation(fields: [interestedPersonId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([email])
  @@index([code])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================================
// EMAIL HTML ELEMENT (Reusable header/footer/custom blocks for emails)
// ============================================================================

model EmailHtmlElement {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "header", "footer"
  name      String   // Display name
  html      String   @db.Text // Inline-styled HTML safe for all email clients
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ============================================================================
// EMAIL TEMPLATE (Notification email templates: subject + body)
// ============================================================================

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "invitation", "email_verification", "password_reset"
  name      String   // Display name
  subject   String   // Subject line; supports {{placeholders}}
  bodyHtml  String   @db.Text // Body only (header/footer wrapped at send time); inline styles, table-based
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ============================================================================
// FEEDBACK (User feedback submissions)
// ============================================================================

model Feedback {
  id        String         @id @default(cuid())
  accountId String
  userId    String
  type      FeedbackType
  subject   String
  message   String         @db.Text
  status    FeedbackStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  account     Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments FeedbackAttachment[]

  @@index([accountId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// FEEDBACK ATTACHMENT (Files attached to feedback)
// ============================================================================

model FeedbackAttachment {
  id         String   @id @default(cuid())
  feedbackId String
  filename   String   // Original filename
  key        String   // R2 object key
  mimeType   String
  size       Int      // File size in bytes
  createdAt  DateTime @default(now())

  // Relations
  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}

// ============================================================================
// ANALYTICS EVENT (First-party lobby event ingest)
// ============================================================================
// Stores raw events emitted by the lobby template's trackEvent helper.
// Dual-fires alongside the customer's GA/GTM (independent destinations).
// Phase-1 is internal-only; lobbyId + accountId are denormalized into every
// row so per-account queries don't need joins when customer dashboards
// land in Phase-2.

model AnalyticsEvent {
  id         String   @id @default(cuid())
  // Server-stamped time-of-ingest. Always present; primary sort key.
  occurredAt DateTime @default(now())
  // Browser-side timestamp the client claimed when emitting the event;
  // optional and unreliable, kept for ordering bursts within a session.
  clientTs   DateTime?

  // Lobby / Account attribution — server-stamped on insert from a Lobby
  // lookup. Client-supplied lobbyId is trusted only until Phase-2 (customer
  // dashboards), at which point the server enforces it from the request's
  // tenant context.
  accountId  String?
  lobbyId    String?

  // First-party visitor / session identifiers, set in HttpOnly cookies
  // (sl_visitor: 1y, sl_session: 30min sliding). Always present from the
  // ingest endpoint — even the first hit mints both.
  sessionId  String
  visitorId  String

  // Optional logged-in lobby user (post password-gate); null for anonymous.
  userId     String?

  // Optional LobbyUser id — set when the visitor has been identified
  // via magic-link or Google sign-in (i.e. session.lobbyUserIds[lobbyId]
  // was present at ingest time). Enables per-visitor aggregations like
  // "tracks listened to by this LobbyUser" without joining through
  // visitorId / sessionId heuristics.
  lobbyUserId String?

  // Event type — short string, e.g. "lobby_password_view", "login",
  // "audio_play", "audio_complete", "track_click". Kept open so new event
  // types don't need a migration.
  eventType  String

  // Optional track scope — set when the event is per-track (audio_play,
  // audio_complete, etc.).
  trackId    String?

  // Request context, server-stamped.
  path       String?
  referrer   String?
  userAgent  String?
  // ISO-3166 country derived from cf-ipcountry (or equivalent) header at
  // ingest time. Never derived from external GeoIP calls on the hot path.
  country    String?

  // Free-form per-event payload (originally the second arg to trackEvent).
  properties Json     @default("{}")

  // Indexes:
  //  - (accountId, occurredAt): account-scoped time-range queries
  //  - (lobbyId, eventType, occurredAt): per-lobby, per-event timelines
  //    (most common dashboard query shape)
  //  - sessionId / visitorId: session reconstruction & distinct counts
  //  - occurredAt: cold archive cursor (Phase-3 export-then-delete)
  @@index([accountId, occurredAt])
  @@index([lobbyId, eventType, occurredAt])
  @@index([sessionId])
  @@index([visitorId])
  @@index([occurredAt])
  // Per-LobbyUser timelines (e.g. the "tracks listened" count on the
  // lobby-users admin route). Composite with eventType keeps that
  // filtered count seek-friendly.
  @@index([lobbyUserId, eventType])
}
